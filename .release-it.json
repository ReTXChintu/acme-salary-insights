{
  "git": {
    "commit": true,
    "tag": true,
    "push": false,
    "requireCleanWorkingDir": true,
    "commitMessage": "chore(release): ${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": ["npm test"],
    "after:bump": "node scripts/sync-package-versions.js && git add frontend/package.json backend/package.json"
  }
}
